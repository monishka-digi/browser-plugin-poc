{
  "manifest_version": 3,
  "name": "Grace API Chrome Extension",
  "version": "1.0.0",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "https://static-app.runasp.net/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://static-app.runasp.net/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ]
}
